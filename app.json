{
  "expo": {
    "name": "FamBee",
    "slug": "fambee",
    "version": "1.1.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFC107"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fambee.chat"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFC107"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "package": "com.fambee.chat",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-android-keyboard-fix",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "FamBee에서 영상통화를 위해 카메라가 필요합니다",
          "microphonePermission": "FamBee에서 통화를 위해 마이크가 필요합니다"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ff01aa8b-14b7-4764-b2a2-8dee540402f4"
      }
    },
    "owner": "smbeat"
  }
}
